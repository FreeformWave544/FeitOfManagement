; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="FeitOfManagement"
run/main_scene="uid://c37ao0ki4pnvw"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

AppConfig="*uid://cjke6crjg14a0"

[display]

window/stretch/mode="canvas_items"

[dotnet]

project/assembly_name="FeitOfManagement"

[editor_plugins]

enabled=PackedStringArray("res://addons/godot_super-wakatime/plugin.cfg", "res://addons/maaacks_options_menus/plugin.cfg")

[internationalization]

locale/translations=PackedStringArray("res://addons/maaacks_options_menus/base/translations/menus_translations.en.translation", "res://addons/maaacks_options_menus/base/translations/menus_translations.fr.translation")

[maaacks_options_menus]

disable_update_check=false
disable_install_wizard=true
copy_path="res://"

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
